include(CMakeFindDependencyMacro)

# Re-discover the dependencies that xmSigma's public (imported) targets reference,
# so downstream find_package(xmSigma) consumers get usable xmotion::interface /
# xmotion::logging / xmotion::xmSigma targets.
find_dependency(Threads REQUIRED)
find_dependency(Eigen3 REQUIRED NO_MODULE)   # xmotion::interface links Eigen3::Eigen
find_dependency(spdlog REQUIRED)             # xmotion::logging links spdlog::spdlog (USE_SYS_SPDLOG)

# Add the targets file
include("${CMAKE_CURRENT_LIST_DIR}/xmSigmaTargets.cmake")
